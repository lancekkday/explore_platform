# ── Ports（EC2 上若有衝突可改這裡）──────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Frontend paths ────────────────────────────────────────────────────────────
# Local dev: BACKEND_URL is the Vite proxy target (only used by vite dev server)
# Docker default (served at root):   VITE_API_URL=/api  VITE_BASE_URL=/
# Docker on EC2 subpath:             VITE_API_URL=/explore_platform/api  VITE_BASE_URL=/explore_platform/
BACKEND_URL=http://localhost:8000
VITE_API_URL=/api
VITE_BASE_URL=/

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── KKDay internal QA service (Playwright cookie fetching) ───────────────────
SECRET_SERVICE_URL=
SERVICE_URL=
AUTOMATION_TOKEN=
BROWSER=
AGENT=
