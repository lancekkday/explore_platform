# ── Frontend proxy target (local dev only) ────────────────────────────────────
# In Docker, nginx handles /api/ → backend:8000 internally.
# This value is only used by Vite dev server proxy.
BACKEND_URL=http://localhost:8000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── KKDay internal QA service (Playwright cookie fetching) ───────────────────
SECRET_SERVICE_URL=
SERVICE_URL=
AUTOMATION_TOKEN=
BROWSER=
AGENT=
