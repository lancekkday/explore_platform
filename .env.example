# ── Ports（EC2 上若有衝突可改這裡）──────────────────────────────────────────────
# EC2 部署預設值：BACKEND_PORT=19426  FRONTEND_PORT=8086
# 本機開發不走 Docker，BACKEND_PORT / FRONTEND_PORT 不影響 vite dev server
BACKEND_PORT=19426
FRONTEND_PORT=8086

# ── Frontend paths ────────────────────────────────────────────────────────────
# Local dev: BACKEND_URL is the Vite proxy target (only used by vite dev server)
# Docker default (served at root):   VITE_API_URL=/api  VITE_BASE_URL=/
# Docker on EC2 subpath (/explore_platform):
#   VITE_API_URL=/explore_platform/api  VITE_BASE_URL=/explore_platform/
#   BACKEND_PORT=19426  FRONTEND_PORT=8086
BACKEND_URL=http://localhost:19426
VITE_API_URL=/api
VITE_BASE_URL=/

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL_NAME=gpt-4o-mini
AI_PRICE_INPUT_PER_1M=0.150
AI_PRICE_OUTPUT_PER_1M=0.600

# ── Destination data (Docker: /app/data, local: path to be2_destinations_dump parent) ──
DEST_DUMP_DIR=

# ── KKDay internal QA service (Playwright cookie fetching) ───────────────────
SECRET_SERVICE_URL=
SERVICE_URL=
AUTOMATION_TOKEN=
BROWSER=
AGENT=
